<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings>
  <category label="General">
    <setting id="language" type="enum" label="Preferred title language"
             values="English|Romaji|Japanese" default="1"/>
  </category>
  <category label="Artwork">
    <setting id="art_source" type="enum" label="Art source"
             values="TMDB + Fanart.tv fallback|TMDB only|Fanart.tv only" default="0"/>
    <setting id="tmdb_api_key" type="text" label="TMDB API Key (v3)" default=""/>
    <setting id="fanarttv_api_key" type="text" label="Fanart.tv API Key" default=""/>
    <setting id="fetch_fanart" type="bool" label="Fetch backgrounds (fanart)" default="true"/>
    <setting id="fetch_clearlogo" type="bool" label="Fetch clearlogo" default="true"/>
    <setting id="fetch_clearart" type="bool" label="Fetch clearart" default="false"/>
    <setting id="fetch_banner" type="bool" label="Fetch banner" default="false"/>
    <setting id="fetch_landscape" type="bool" label="Fetch landscape" default="false"/>
    <setting id="fetch_thumbnail" type="bool" label="Fetch thumbnail" default="false"/>
  </category>
</settings>
